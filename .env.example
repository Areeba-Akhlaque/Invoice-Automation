# Copy to .env and fill in. (In GitHub Actions, set these as repo Secrets instead.)

# ── Kimai ─────────────────────────────────────────────────────
KIMAI_URL=https://kimai.yourcompany.com
KIMAI_TOKEN=your_kimai_api_token
KIMAI_USER=            # only for legacy Kimai 1.x; leave blank for 2.x bearer tokens
KIMAI_VERIFY_SSL=true

# ── Gemini (AI project descriptions) ──────────────────────────
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Google Sheets ─────────────────────────────────────────────
# CLOUD / headless (recommended for GitHub Actions): paste the service-account
# JSON (one line) and share the sheet with the service-account email as Editor.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
#
# LOCAL dev (interactive): leave the above blank and keep a client_secret_*.json
# in the project root; the first run opens a browser and caches token.json.
